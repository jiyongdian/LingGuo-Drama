APP_NAME=灵果短剧
APP_ENV=local
APP_KEY=zBqYyQrPNaIUsnRhsGtHLivjqiMjBVLS
APP_DEBUG=true
APP_URL=http://localhost:8080/
APP_PORT=8080

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=spirit_fruit
DB_USERNAME=root
DB_PASSWORD=123456
DB_DEBUG=2

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_CACHE_DB=0
REDIS_MAIN_DB=1
REDIS_ASYNC_DB=0

JWT_EXPIRE_TIME=120
JWT_MAX_REFRESH_TIME=86400

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=灵果短剧@example.com
MAIL_FROM_NAME=灵果短剧

LOG_TYPE=single
LOG_LEVEL=debug


# ==============================
# AI Service Configuration
# ==============================

# 当前使用的 AI 提供商 (openai 或 gemini)
AI_PROVIDER=openai

# --- OpenAI 配置 ---
# 如果使用官方接口: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_IMAGE_MODEL=dall-e-3

# --- GetGoAPI 配置 (综合中转平台，可代理 Sora 等) ---
# GetGoAPI 文本接口通常与 OpenAI 兼容
GETGOAPI_BASE_URL=https://api.getgoapi.com/v1
GETGOAPI_API_KEY=sk-xxxxxx
# 文本模型 (例如: gpt-4o, claude-3-5-sonnet)
GETGOAPI_MODEL=gpt-4o
# 绘画模型 (例如: gpt-4o-image, flux-1-pro, midjourney)
GETGOAPI_IMAGE_MODEL=gpt-4o-image

# --- Doubao (火山引擎/豆包大模型) 配置 ---
# 火山引擎官方推理地址: https://ark.cn-beijing.volces.com/api/v3
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your_doubao_api_key_here
# ⚠️ 注意：豆包的 MODEL 必须填入火山引擎控制台中的【接入点 ID (Endpoint ID)】
# 文本模型接入点 (用于剧本拆解)
DOUBAO_MODEL=ep-202405xxxxxxxx-text
# 生图模型接入点 (用于生成角色、场景图)
DOUBAO_IMAGE_MODEL=ep-202405xxxxxxxx-image

# --- Vertex AI 配置 ---
VERTEX_API_KEY=AIzaSyBxxxxxxxxxxxxxxxxxxxxx # API 密钥
VERTEX_MODEL=gemini-1.5-pro
VERTEX_IMAGE_MODEL=imagen-3.0-generate-001

# --- Gemini 配置 ---
# Google 官方地址通常是: https://generativelanguage.googleapis.com/v1beta
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-pro

# ==============================
# AI Video Generation Configuration
# ==============================

# 默认的视频生成提供商 (如果前端未指定，则使用此提供商)
VIDEO_PROVIDER=getgoapi

# --- Vertex AI (Google Cloud Veo) 视频配置 ---
VERTEX_VIDEO_MODEL=veo-2.0-generate-001
VERTEX_PROJECT_ID=
VERTEX_REGION=us-central1

# --- Volces (火山引擎 / 豆包 Seedance) 配置 ---
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCES_API_KEY=your_volces_key_here

# --- MiniMax (海螺) 配置 ---
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_API_KEY=your_minimax_key_here

# --- Runway 配置 ---
RUNWAY_BASE_URL=https://api.runwayml.com
RUNWAY_API_KEY=your_runway_key_here

# --- Pika 配置 ---
PIKA_BASE_URL=https://api.pika.art
PIKA_API_KEY=your_pika_key_here
